FLASK_ENV=development
PORT=8000

# JobSpy scraping settings
DEFAULT_RESULTS_WANTED=20
DEFAULT_HOURS_OLD=72
SCRAPE_DELAY_SECONDS=1.0

# CORS — allow only the Node backend
ALLOWED_ORIGIN=http://localhost:5000

# PostgreSQL — matches the docker-compose postgres service defaults
DB_HOST=127.0.0.1
DB_PORT=5435
DB_NAME=careerpilot
DB_USER=careerpilot
DB_PASSWORD=careerpilot123
# Or use a full DSN (takes precedence over individual vars above):
# DATABASE_URL=postgresql://careerpilot:careerpilot123@127.0.0.1:5435/careerpilot
